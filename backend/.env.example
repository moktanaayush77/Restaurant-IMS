# Copy to .env and adjust. Local dev works with NO .env at all (SQLite + in-memory channels).

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# Comma-separated. Use * in DEBUG; on the server list the LAN IP/hostname.
ALLOWED_HOSTS=*
TIME_ZONE=Asia/Kathmandu

# --- Database ---
# Leave unset to use the local SQLite file. On the in-house server use PostgreSQL:
# DATABASE_URL=postgres://restaurant:password@localhost:5432/restaurant

# --- Real-time (Channels) ---
# Leave unset for the in-memory layer (single-process dev). On the server use Redis:
# REDIS_URL=redis://localhost:6379/0

# --- CORS / CSRF (only needed if the frontend is served from another origin) ---
# CORS_ALLOW_ALL_ORIGINS=True
# CORS_ALLOWED_ORIGINS=http://192.168.1.50:5173
# CSRF_TRUSTED_ORIGINS=http://192.168.1.50:5173
