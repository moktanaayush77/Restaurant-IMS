# Copy to deploy/.env and fill in before running docker compose.

# A long random string. Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# The server's LAN hostname/IP plus localhost. Example:
#   ALLOWED_HOSTS=192.168.1.50,restaurant.local,localhost
ALLOWED_HOSTS=*

# Database credentials (used to build DATABASE_URL inside compose).
POSTGRES_DB=restaurant
POSTGRES_USER=restaurant
POSTGRES_PASSWORD=change-this-password

TIME_ZONE=Asia/Kathmandu

# If the browser reaches the server by a specific origin, list it here:
#   CSRF_TRUSTED_ORIGINS=http://192.168.1.50
CSRF_TRUSTED_ORIGINS=

# Set to true ONLY on the very first run to load demo staff/menu/tables.
SEED_DEMO=false
